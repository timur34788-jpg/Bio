{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      ".read": true,
      ".write": false
    },
    "uidMap": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    },
    "users": {
      ".read": true,
      ".write": true,
      "$username": {
        ".indexOn": [
          "lastSeen"
        ],
        "ipHistory": {
          ".read": true,
          ".write": true
        },
        "lastIP": {
          ".read": true,
          ".write": true
        },
        "isAdmin": {
          ".read": true,
          ".write": false
        },
        "banReason": {
          ".read": true,
          ".write": true
        }
      }
    },
    "online": {
      ".read": true,
      ".write": true
    },
    "rooms": {
      ".read": true,
      ".write": true
    },
    "msgs": {
      "$roomId": {
        ".read": true,
        ".write": true,
        ".indexOn": [
          "ts"
        ]
      }
    },
    "dms": {
      ".read": true,
      ".write": true,
      "$chatId": {
        "messages": {
          ".indexOn": [
            "ts"
          ]
        }
      }
    },
